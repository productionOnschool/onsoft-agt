AGT_AMBIENTE=sandbox
# sandbox  -> https://sifphml.minfin.gov.ao  (homologacao)
# producao -> https://sifp.minfin.gov.ao

AGT_SCHEMA_VERSION=1.2

# ---------------------------------------------------------------------------
# CHAVE DO SOFTWARE (FABRICANTE - ONSOFT/ADILSON MIGUEL)
# ---------------------------------------------------------------------------
# Gerada LOCALMENTE pelo produtor - a chave privada NUNCA sai deste
# servidor. A chave PUBLICA e submetida no Portal do Parceiro:
#   Testes:   https://portaldoparceiro.hml.minfin.gov.ao/
#   Producao: https://portaldoparceiro.minfin.gov.ao/
#
#   openssl genrsa -out software_privada.pem 4096
#   openssl rsa -in software_privada.pem -pubout -out software_publica.pem
# ---------------------------------------------------------------------------

AGT_SOFTWARE_CHAVE_PRIVADA="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
AGT_SOFTWARE_CHAVE_PUBLICA="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"
AGT_SOFTWARE_NUMERO_CERTIFICACAO=C_134
AGT_SOFTWARE_NOME="Onsoft AGT"
AGT_SOFTWARE_VERSAO=1.0.0

# ---------------------------------------------------------------------------
# CHAVE DO CONTRIBUINTE - NAO se configura aqui
# ---------------------------------------------------------------------------
# E EMITIDA PELA AGT e fica disponivel no Portal do Contribuinte de
# cada organizacao. NAO e gerada localmente. Configurar via painel
# administrativo (AGT -> Configuracao -> Chaves do Contribuinte).

# ---------------------------------------------------------------------------
# CREDENCIAIS DE BASIC AUTH - por organizacao, NAO aqui
# ---------------------------------------------------------------------------
# Email: produtores.dfe.dcrr.agt@minfin.gov.ao (Nome da Empresa + NIF)
# Guardadas em organization_agt_configs.agt_basic_auth_*

AGT_MOEDA_PADRAO=AOA
AGT_TAMANHO_LOTE=30
